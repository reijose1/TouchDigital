---
/**
 * Services — Section showcasing the 4 core service offerings.
 * Reads from services.json and renders as a responsive card grid.
 */
import Card from '../ui/Card.astro';
import servicesData from '../../data/services.json';

interface ServiceItem {
  id: number;
  title_es: string;
  title_en: string;
  description_es: string;
  description_en: string;
  icon: string;
  link: string;
}

const services = servicesData as ServiceItem[];
---

<section
  id="servicios"
  class="services-section"
  aria-label="Nuestros servicios — Soluciones integrales para tu marca"
>
  <div class="section-container">
    <div class="services-header reveal">
      <span class="services-tag text-ui">
        <span class="lang-es">Especialidades</span>
        <span class="lang-en">Expertise Areas</span>
      </span>
      <h2 class="text-h2 services-title mt-2">
        <span class="lang-es">Nuestros Servicios</span>
        <span class="lang-en">Our Digital Services</span>
      </h2>
      <div class="title-underline"></div>
      <p class="services-subtitle text-body mt-4">
        <span class="lang-es">Soluciones integrales para tu marca, diseñadas para potenciar tu presencia y optimizar tus procesos.</span>
        <span class="lang-en">We integrate digital design, high-efficiency media, and cloud services to design flexible, robust architectures.</span>
      </p>
    </div>

    <div class="services-grid reveal reveal-stagger">
      {services.map((service, index) => (
        <Card
          title_es={service.title_es}
          title_en={service.title_en}
          description_es={service.description_es}
          description_en={service.description_en}
          icon={service.icon}
          linkHref={`${import.meta.env.BASE_URL}${service.link.replace(/^\//, '')}`}
          variant={index % 2 === 1 ? 'dark' : 'light'}
        />
      ))}
    </div>
  </div>
</section>

<style>
  .services-section {
    background: var(--color-bg-light);
    padding: clamp(4rem, 8vw, 8rem) 0;
    position: relative;
    border-top: 1px solid rgba(205, 187, 176, 0.2);
    border-bottom: 1px solid rgba(205, 187, 176, 0.2);
  }

  .services-header {
    text-align: center;
    max-width: 700px;
    margin: 0 auto 4rem;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .services-tag {
    color: var(--color-accent-honeysuckle);
    font-size: 13px;
    letter-spacing: 0.15em;
    font-weight: 700;
  }

  .services-title {
    color: var(--color-primary-lilac);
  }

  .title-underline {
    height: 3px;
    width: 60px;
    background-color: var(--color-accent-honeysuckle);
    border-radius: 99px;
    margin-top: 0.75rem;
  }

  .services-subtitle {
    color: var(--color-text-muted);
  }

  .services-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 1.5rem;
    max-width: 1140px;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .services-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
