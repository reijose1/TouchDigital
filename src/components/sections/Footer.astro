---
/**
 * Footer — Elegant footer with brand info, links, contact, social icons, and signature.
 * Deep Lilac background with Nude text.
 */

interface QuickLink {
  /** Link display text in Spanish */
  labelEs: string;
  /** Link display text in English */
  labelEn: string;
  /** Anchor href */
  href: string;
}

interface SocialLink {
  /** Platform name */
  name: string;
  /** Full URL (placeholder) */
  href: string;
  /** Accessible label */
  ariaLabel: string;
  /** SVG path data for the icon */
  iconPath: string;
}

const quickLinks: QuickLink[] = [
  { labelEs: 'Inicio', labelEn: 'Home', href: '#hero' },
  { labelEs: 'Programas', labelEn: 'Programs', href: '#servicios' },
  { labelEs: 'Acerca de', labelEn: 'About Us', href: '#about' },
  { labelEs: 'Portafolio', labelEn: 'Portfolio', href: '#portafolio' },
  { labelEs: 'Contacto', labelEn: 'Contact', href: '#contacto' },
];

/**
 * Social media links with placeholder URLs.
 */
const socialLinks: SocialLink[] = [
  {
    name: 'YouTube',
    href: 'https://www.youtube.com/@ReinaldoCarrilloRoldan',
    ariaLabel: 'Visita nuestro canal de YouTube',
    iconPath: 'M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z',
  },
  {
    name: 'GitHub',
    href: 'https://github.com/reijose1',
    ariaLabel: 'Visita nuestro perfil de GitHub',
    iconPath: 'M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12',
  },
  {
    name: 'LinkedIn',
    href: 'www.linkedin.com/in/reinaldocarrillo',
    ariaLabel: 'Visita nuestro perfil de LinkedIn',
    iconPath: 'M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z',
  },
];
---

<footer
  class="footer"
  role="contentinfo"
  aria-label="Pie de página — Touch Digital"
>
  <div class="section-container">
    <div class="footer-grid">
      <!-- Column 1: Brand -->
      <div class="footer-col footer-brand">
        <img
          src={`${import.meta.env.BASE_URL}assets/logos/brand-logo.webp`}
          alt="Learning Touch — Logo de la marca"
          width="340"
          height="85"
          loading="lazy"
          decoding="async"
          class="footer-logo"
        />
        <p class="footer-desc text-body">
          <span class="lang-es">Transformamos ideas en experiencias digitales memorables.</span>
          <span class="lang-en">We transform ideas into memorable digital experiences.</span>
        </p>
      </div>

      <!-- Column 2: Quick Links -->
      <nav class="footer-col footer-links" aria-label="Enlaces rápidos">
        <h3 class="footer-col-title text-ui">
          <span class="lang-es">Enlaces</span>
          <span class="lang-en">Links</span>
        </h3>
        <ul class="footer-link-list">
          {quickLinks.map((link) => (
            <li>
              <a href={link.href} class="footer-link text-body">
                <span class="lang-es">{link.labelEs}</span>
                <span class="lang-en">{link.labelEn}</span>
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <!-- Column 3: Contact Info -->
      <div class="footer-col footer-contact">
        <h3 class="footer-col-title text-ui">
          <span class="lang-es">Contacto</span>
          <span class="lang-en">Contact</span>
        </h3>
        <ul class="footer-contact-list">
          <li class="footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
            <a href="tel:+573103435263" class="footer-contact-link">+57 3103435263</a>
          </li>
          <li class="footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <a href="mailto:reijose1@gmail.com" class="footer-contact-link">reijose1@gmail.com</a>
          </li>
          <li class="footer-contact-item">
            <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
            <span class="footer-contact-text text-small">
              Carrera 9 # 17-24 sur torre 6 apto 324, Mosquera Cundinamarca, Colombia.
            </span>
          </li>
        </ul>
      </div>

      <!-- Column 4: Social + Signature -->
      <div class="footer-col footer-social">
        <h3 class="footer-col-title text-ui">
          <span class="lang-es">Síguenos</span>
          <span class="lang-en">Follow Us</span>
        </h3>
        <div class="social-icons">
          {socialLinks.map((social) => (
            <a
              href={social.href}
              target="_blank"
              rel="noopener noreferrer"
              class="social-icon-link"
              aria-label={social.ariaLabel}
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d={social.iconPath} />
              </svg>
            </a>
          ))}
        </div>

        <!-- Firma: caption superpuesto sobre parte inferior de la imagen -->
        <div class="footer-signature">
          <div class="signature-frame">
            <img
              src={`${import.meta.env.BASE_URL}assets/footer/signature.webp`}
              alt="Firma Reinaldo Carrillo"
              width="105"
              height="43.5"
              loading="lazy"
              decoding="async"
              class="signature-img"
            />
            <p class="signature-caption">
              <span class="lang-es">Diseñado con pasión por Reinaldo Carrillo.</span>
              <span class="lang-en">Crafted with passion by Reinaldo Carrillo.</span>
            </p>
          </div>
        </div>
      </div>
    </div>

    <!-- Bottom Bar -->
    <div class="footer-bottom">
      <p class="text-small footer-copyright">
        <span class="lang-es">© {new Date().getFullYear()} Learning Touch — Touch Digital & Creative Consulting. Todos los derechos reservados.</span>
        <span class="lang-en">© {new Date().getFullYear()} Learning Touch — Touch Digital & Creative Consulting. All rights reserved.</span>
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-bg-dark);
    padding: clamp(3rem, 6vw, 5rem) 0 2rem;
    border-top: 1px solid rgba(205, 187, 176, 0.1);
  }

  .footer-grid {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1.5fr 1fr;
    gap: 2.5rem;
    padding-bottom: 3rem;
    border-bottom: 1px solid rgba(205, 187, 176, 0.1);
  }

  /* --- Column Styles --- */
  .footer-col-title {
    color: #fff;
    margin-bottom: 1.25rem;
    font-size: 14px;
    letter-spacing: 0.1em;
  }

  /* Brand */
  .footer-logo {
    width: clamp(200px, 22vw, 320px);
    height: auto;
    margin-bottom: 1.25rem;
    object-fit: contain;
    display: block;
  }

  .footer-desc {
    color: var(--color-text-inverse);
    opacity: 0.7;
    font-size: 15px;
    line-height: 1.6;
  }

  /* Quick Links */
  .footer-link-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .footer-link {
    color: var(--color-text-inverse);
    text-decoration: none;
    font-size: 15px;
    transition:
      color var(--duration-micro) var(--ease-micro),
      transform var(--duration-micro) var(--ease-micro);
    display: inline-block;
  }

  .footer-link:hover {
    color: var(--color-accent-honeysuckle);
    transform: translateX(4px);
  }

  /* Contact */
  .footer-contact-list {
    list-style: none;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .footer-contact-item {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    color: var(--color-text-inverse);
    opacity: 0.8;
    font-size: 14px;
    line-height: 1.5;
  }

  .footer-contact-item svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-accent-honeysuckle);
  }

  .footer-contact-link {
    color: var(--color-text-inverse);
    text-decoration: none;
    transition: color var(--duration-micro) var(--ease-micro);
  }

  .footer-contact-link:hover {
    color: var(--color-accent-honeysuckle);
  }

  .footer-contact-text {
    color: var(--color-text-inverse);
    opacity: 0.8;
  }

  /* Social Icons */
  .social-icons {
    display: flex;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .social-icon-link {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 42px;
    height: 42px;
    border-radius: 12px;
    background: rgba(205, 187, 176, 0.1);
    color: rgba(205, 187, 176, 0.7);
    text-decoration: none;
    transition:
      color var(--duration-micro) var(--ease-micro),
      background var(--duration-micro) var(--ease-micro),
      transform var(--duration-micro) var(--ease-micro);
  }

  .social-icon-link:hover {
    color: var(--color-accent-honeysuckle);
    background: rgba(194, 82, 112, 0.15);
    transform: scale(1.15);
  }

  /* Signature — columna Sidebar (col 4) */
  .footer-signature {
    margin-top: 1.25rem;
    padding-top: 1rem;
    border-top: 1px solid rgba(205, 187, 176, 0.15);
  }

  /* Wrapper con caption superpuesto */
  .signature-frame {
    position: relative;
    display: inline-block;
    line-height: 0; /* elimina espacio extra bajo la imagen */
  }

  .signature-img {
    width: clamp(120px, 11vw, 160px);
    height: auto;
    filter: invert(1) sepia(0.2) brightness(0.85);
    opacity: 0.88;
    display: block;
  }

  .signature-caption {
    position: absolute;
    bottom: 6px;      /* monta el texto sobre el borde inferior de la imagen */
    left: 0;
    right: 0;
    text-align: left;
    font-size: 10px;
    font-style: italic;
    line-height: 1.3;
    color: var(--color-text-inverse);
    opacity: 0.6;
    /* sombra leve para legibilidad sobre la imagen */
    text-shadow: 0 1px 4px rgba(59, 34, 68, 0.6);
    padding: 0 2px;
  }

  /* Bottom Bar */
  .footer-bottom {
    padding-top: 1.5rem;
    text-align: center;
  }

  .footer-copyright {
    color: var(--color-text-inverse);
    opacity: 0.4;
    font-size: 13px;
  }

  /* Responsive */
  @media (max-width: 1024px) {
    .footer-grid {
      grid-template-columns: 1fr 1fr;
      gap: 2rem;
    }
  }

  @media (max-width: 640px) {
    .footer-grid {
      grid-template-columns: 1fr;
      text-align: center;
    }

    .footer-logo {
      margin-left: auto;
      margin-right: auto;
    }

    .social-icons {
      justify-content: center;
    }

    .footer-signature {
      align-items: center;
    }

    .footer-contact-item {
      justify-content: center;
    }
  }
</style>
