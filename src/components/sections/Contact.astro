---
/**
 * Contact — Final CTA section with contact form.
 * Dark Lilac background with organic texture overlay.
 * Imports ContactForm React island for EmailJS integration.
 *
 * Implements:
 * - content-spec.md Section 5 (Final CTA copy)
 * - component-blueprint.md Section 5 (ContactForm)
 */
import ContactForm from '../react/ContactForm.tsx';
---

<section
  id="contacto"
  class="contact-section"
  aria-label="Contacto — Hablemos de tu próximo proyecto"
>
  <!-- Organic texture overlay -->
  <div class="contact-texture" aria-hidden="true"></div>

  <div class="section-container contact-container">
    <div class="contact-copy reveal">
      <h2 class="text-h2 contact-title">
        <span class="lang-es">¿Listo para dar el siguiente clic?</span>
        <span class="lang-en">Ready to take the next click?</span>
      </h2>
      <p class="contact-subtitle text-body-lg">
        <span class="lang-es">Hablemos de tu próximo proyecto.</span>
        <span class="lang-en">Let's talk about your next project.</span>
      </p>
    </div>

    <div class="contact-form-wrapper reveal">
      <ContactForm client:visible />
    </div>
  </div>
</section>

<style>
  .contact-section {
    background: var(--color-bg-dark);
    padding: clamp(4rem, 8vw, 8rem) 0;
    position: relative;
    overflow: hidden;
  }

  .contact-texture {
    position: absolute;
    inset: 0;
    background:
      radial-gradient(
        circle at 20% 80%,
        rgba(194, 82, 112, 0.08) 0%,
        transparent 50%
      ),
      radial-gradient(
        circle at 80% 20%,
        rgba(205, 187, 176, 0.06) 0%,
        transparent 50%
      );
    pointer-events: none;
  }

  .contact-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 4rem;
    position: relative;
    z-index: 2;
  }

  .contact-copy {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .contact-title {
    color: var(--color-primary-nude);
  }

  .contact-subtitle {
    color: rgba(205, 187, 176, 0.7);
  }

  .contact-form-wrapper {
    background: rgba(59, 34, 68, 0.6);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border: 1px solid rgba(205, 187, 176, 0.12);
    border-radius: 20px;
    padding: 2.5rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.2);
  }

  @media (max-width: 768px) {
    .contact-container {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
    }

    .contact-form-wrapper {
      padding: 1.5rem;
    }
  }
</style>
