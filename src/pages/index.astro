---
/**
 * index.astro — Homepage: The narrative journey.
 * Section order:
 *   1. MegaMenu (Navigation)
 *   2. Hero (Immediate Impact)
 *   3. Services (The "What")
 *   4. EducationImpact (The "Why")
 *   5. Portfolio (The "How")
 *   6. Contact / Final CTA (Conversion)
 *   7. Footer (Impact & Elegance)
 */
import Layout from '../layouts/Layout.astro';
import MegaMenu from '../components/ui/MegaMenu.astro';
import Hero from '../components/sections/Hero.astro';
import Services from '../components/sections/Services.astro';
import EducationImpact from '../components/sections/EducationImpact.astro';
import Portfolio from '../components/sections/Portfolio.astro';
import Contact from '../components/sections/Contact.astro';
import Footer from '../components/sections/Footer.astro';
---

<Layout
  title="Learning Touch — Knowledge in one Clic"
  description="Formamos estudiantes con pensamiento crítico, herramientas digitales y valores sólidos. Desarrollo web, publicidad digital, recursos educativos y redes sociales."
>
  <MegaMenu />
  <main id="main-content">
    <Hero />
    <Services />
    <EducationImpact />
    <Portfolio />
    <Contact />
  </main>
  <Footer />
</Layout>
